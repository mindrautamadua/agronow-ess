# ─────────────────────────────────────────────────────────────────────────────
# Agronow ESS — environment. Copy ke `.env.local` lalu isi nilainya.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Postgres (project `agronow`) — Session pooler URI (lihat Supabase → Connect).
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
PG_POOL_LIMIT=10

# Supabase Storage — upload dokumentasi IDP (PDF) ke bucket `idp-docs`.
# service_role key: Supabase → Project Settings → API → service_role (RAHASIA, server-only).
SUPABASE_URL=https://fnzyrubjhskxkxqdjwdx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role, jangan pernah diekspos ke client)

# Login: API SSO holding (validasi NIK + password). Default sudah benar.
HOLDING_LOGIN_URL=https://apis.holding-perkebunan.com/access/login
# Rahasia tanda tangan cookie sesi (HMAC). WAJIB di produksi, min 16 char.
SESSION_SECRET=ganti-dengan-string-acak-panjang

# Member fallback saat tidak ada sesi login (dev only). Di produksi user wajib login.
CURRENT_MEMBER_ID=6063

# AI Coach (OpenAI) — model gpt-4o-mini. Tanpa ini, fitur /coach nonaktif.
OPENAI_API_KEY=sk-...

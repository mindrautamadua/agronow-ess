# ─────────────────────────────────────────────────────────────────────────────
# Agronow ESS — environment. Copy ke `.env.local` lalu isi nilainya.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Postgres (project `agronow`) — Session pooler URI (lihat Supabase → Connect).
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
PG_POOL_LIMIT=10

# Member yang sedang login (sementara di-hardcode karena login masih bypass).
CURRENT_MEMBER_ID=6063

# AI Coach (OpenAI) — model gpt-4o-mini. Tanpa ini, fitur /coach nonaktif.
OPENAI_API_KEY=sk-...
